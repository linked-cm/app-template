# App environment for local (standalone) dev.
#
# `linked start` loads this file natively via Node's `process.loadEnvFile` — no
# dependency. `.env` is gitignored; `npm start`/`npm run build` copy this example
# to `.env` on first run (scripts/ensure-env.cjs), so a fresh clone just works.
# In production the host REPLACES `.env` or injects these as real environment
# variables — the shell environment always wins over values in the file.
#
# When CN hosts this app it injects the dynamic per-(project, branch) vars
# (PORT, FUSEKI_DATASET, the admin secret, the EG gateway) at spawn time; those
# take precedence over anything here.

# --- App identity -------------------------------------------------------------
APP_NAME=Linked App Template
APP_PREFIX=app
DATA_ROOT=http://localhost:4000/data

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
PORT=4000
SITE_ROOT=http://localhost:4000
SOURCE_PATH=./src

# --- Data store (standalone-dev defaults; CN injects per branch when hosting) --
FUSEKI_BASE_URL=http://localhost:3030
FUSEKI_DATASET=app-main
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin
