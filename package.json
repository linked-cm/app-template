{
  "name": "${hyphen_name}",
  "displayName": "${name}",
  "description": "Linked app — base repository CN clones for every new project.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "linkedApp": true,
  "author": {
    "name": "",
    "url": "",
    "email": ""
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "main": "scripts/start-server.js",
  "exports": {
    "./backend": {
      "development": "./src/backend.ts",
      "default": "./src/backend.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "start": "linked start --env development",
    "build": "linked build-app --env production",
    "server:prod": "NODE_ENV=production linked start --env production",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx,css,scss}\" --check",
    "prettier:fix": "npm run prettier -- --write",
    "format": "npm run prettier:fix && npm run lint:fix"
  },
  "keywords": [
    "linked",
    "linked code",
    "linked data",
    "structured data",
    "RDF",
    "semantic web",
    "web3"
  ],
  "dependencies": {
    "@_linked/core": "^2.12",
    "@_linked/fuseki": "^2.0",
    "@_linked/react": "^1.4",
    "@_linked/schema": "^1.0.6",
    "@_linked/server": "^2.1",
    "@_linked/server-utils": "^1.0.6",
    "react": "^18.2",
    "react-dom": "^18.2",
    "react-error-boundary": "^3.1.3",
    "react-router-dom": "^6.3.0"
  },
  "devDependencies": {
    "@_linked/cli": "^1.8",
    "@types/node": "^20.12.7",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "^8.9.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "nodemon": "^2.0.22",
    "pm2": "^5.3.0",
    "typescript-plugin-css-modules": "^5.1.0",
    "which": "^3.0.1"
  },
  "packageManager": "yarn@3.6.1",
  "repository": {
    "type": "git",
    "url": "git@github.com:linked-cm/app-template.git"
  }
}
